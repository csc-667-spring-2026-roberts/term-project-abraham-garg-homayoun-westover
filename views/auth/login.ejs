<%- include("../partials/header", { title, currentUserId }) %>

<section class="auth-card">
  <div class="auth-hero">
    <div class="spade-mark">♠</div>
    <h1>Welcome Back</h1>
    <p>Sign in to join a Spades table, place your bid, and play your hand.</p>
  </div>

  <div class="auth-panel">
    <h2>Login</h2>
    <p class="muted-text">Sign in with your email and password.</p>

    <% if (error) { %>
      <p class="error-msg"><%= error %></p>
    <% } %>

    <form action="/auth/login" method="POST" class="auth-form">
      <label for="email">Email</label>
      <div class="input-wrap">
        <span>✉️</span>
        <input id="email" name="email" type="email" required value="<%= email || '' %>" placeholder="Enter your email" />
      </div>

      <label for="password">Password</label>
      <div class="input-wrap">
        <span>🔒</span>
        <input id="password" name="password" type="password" required placeholder="Enter your password" />
      </div>

      <button type="submit">Login</button>
    </form>

    <p class="switch-link">Need an account? <a href="/auth/register">Register</a>.</p>
  </div>
</section>

<%- include("../partials/footer") %>