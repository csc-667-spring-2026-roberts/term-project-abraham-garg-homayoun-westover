<%- include("partials/header", { title, currentUserId }) %>

<h1>Authenticated Lobby</h1>
<p class="muted-text">You are logged in and can access protected content.</p>

<ul class="info-list">
  <li><strong>User ID:</strong> <%= user.id %></li>
  <li><strong>Email:</strong> <%= user.email %></li>
  <li><strong>Member since:</strong> <%= user.created_at.toISOString() %></li>
</ul>

<p>Try visiting <code>/api/protected</code> while logged in.</p>


<h2>Test Client Interaction</h2>

<button id="loadBtn">Create Game</button>

<template id="itemTemplate">
  <div class="item">
    <p class="name"></p>
  </div>
</template>

<div id="container"></div>
<script>
  const source = new EventSource("/api/sse?roomId=global");

  source.addEventListener("state-update", (event) => {
    console.log(JSON.parse(event.data));
  });
</script>

