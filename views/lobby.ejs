<%- include("partials/header", { title, currentUserId }) %>

<h1>Spades</h1>
<p class="muted-text">Welcome, <%= user.username %>! Create or join a game below.</p>

<ul class="info-list">
  <li><strong>User ID:</strong> <%= user.id %></li>
  <li><strong>Email:</strong> <%= user.email %></li>
  <li><strong>Member since:</strong> <%= user.created_at.toISOString() %></li>
</ul>

<h2>Games</h2>

<button id="loadBtn">Create New Game</button>

<template id="itemTemplate">
  <div class="item">
    <p class="name"></p>
  </div>
</template>

<div id="container"></div>

<%- include("partials/footer") %>
